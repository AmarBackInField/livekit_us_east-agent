# Copy this file to `.env` and fill in real values.
# DO NOT commit `.env` — it is gitignored.

# LLM provider: groq | openai | google
LLM_PROVIDER=groq

# LiveKit Cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_SIP_TRUNK_ID=

# STT
DEEPGRAM_API_KEY=

# TTS
CARTESIA_API_KEY=
ELEVEN_API_KEY=

# LLM API keys (set the one that matches LLM_PROVIDER above)
GROQ_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Database
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.example.mongodb.net/?retryWrites=true&w=majority
DB_NAME=livekit_agents

# Optional: Redis for distributed call state
# REDIS_URL=redis://localhost:6379/0
